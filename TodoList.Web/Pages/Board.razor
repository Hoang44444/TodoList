@page "/board"
@layout BlankLayout
@using System.Globalization
@inject ITodoApiService Api

<PageTitle>studylist</PageTitle>

<div class="board-root">

    @* ---------- HEADER ---------- *@
    <header class="bd-header">
        <div class="bd-logo-badge">✓</div>
        <div class="bd-logo">studylist</div>
        <div class="bd-tabs">
            @foreach (var tab in Tabs)
            {
                <button class="bd-tab @(tab == _activeTab ? "active" : "")" @onclick="() => _activeTab = tab">@tab</button>
            }
        </div>
        <div class="bd-spacer"></div>
        <div class="bd-date">@DateTime.Today.ToString("ddd, MMM d", CultureInfo.InvariantCulture)</div>
        <input class="bd-search" placeholder="⌕ Tìm công việc" @bind="_search" @bind:event="oninput" />
        <button class="bd-add" @onclick="OpenComposer">+ Thêm</button>
    </header>

    @if (_error is not null)
    {
        <div class="bd-error">@_error</div>
    }

    @* ---------- STATS STRIP ---------- *@
    <div class="bd-stats">
        <div class="bd-stat">
            <div class="bd-stat-label">Hôm nay</div>
            <div class="bd-stat-val">@TodayDone <span class="bd-stat-sub">/ @TodayTotal xong</span></div>
        </div>
        <div class="bd-stat">
            <div class="bd-stat-label">Đang làm</div>
            <div class="bd-stat-val purple">@InProgressCount</div>
        </div>
        <div class="bd-stat">
            <div class="bd-stat-label">Trễ hạn</div>
            <div class="bd-stat-val red">@OverdueCount</div>
        </div>
        <div class="bd-stat">
            <div class="bd-stat-label">Hoàn thành</div>
            <div class="bd-stat-val green">@DoneTotal</div>
        </div>
    </div>

    @* ---------- BOARD ---------- *@
    @if (_todos is null)
    {
        <div class="bd-loading">Đang tải…</div>
    }
    else if (_activeTab == "Board")
    {
        <div class="bd-board">
            @foreach (var col in Columns())
            {
                <section class="bd-col">
                    <div class="bd-col-head">
                        <span class="bd-col-dot" style="background:@col.Color"></span>
                        <span class="bd-col-label" style="color:@col.Color">@col.Label</span>
                        <span class="bd-col-count">@col.Tasks.Count</span>
                    </div>
                    <div class="bd-col-body">
                        @foreach (var t in col.Tasks)
                        {
                            @Card(t)
                        }
                        @if (col.Key == "todo")
                        {
                            <button class="bd-quick-add" @onclick="OpenComposer">+ Thêm công việc</button>
                        }
                        else if (col.Tasks.Count == 0)
                        {
                            <div class="bd-empty">@col.Empty</div>
                        }
                    </div>
                </section>
            }
        </div>
    }
    else if (_activeTab == "List")
    {
        var groups = Columns().Where(c => c.Tasks.Count > 0).ToList();
        <div class="bd-list">
            @if (groups.Count == 0)
            {
                <div class="bd-list-empty">Không có công việc nào</div>
            }
            @foreach (var col in groups)
            {
                <div class="bd-list-group">
                    <div class="bd-list-head">
                        <span class="bd-list-dot" style="background:@col.Color"></span>
                        <span class="bd-list-label" style="color:@col.Color">@col.Label</span>
                        <span class="bd-list-count">@col.Tasks.Count</span>
                    </div>
                    @foreach (var t in col.Tasks)
                    {
                        @Row(t)
                    }
                </div>
            }
        </div>
    }
    else if (_activeTab == "Week")
    {
        <div class="bd-week">
            @foreach (var day in WeekDays())
            {
                var isToday = day == Today;
                var dayTasks = Filtered().Where(t => t.DueDate?.Date == day).ToList();
                <div class="bd-week-day">
                    <div class="bd-week-head @(isToday ? "today" : "")">
                        <span class="bd-week-dow">@DowVi(day)</span>
                        <span class="bd-week-date">@day.ToString("dd/MM")</span>
                        @if (isToday)
                        {
                            <span class="bd-week-today">hôm nay</span>
                        }
                    </div>
                    @foreach (var t in dayTasks)
                    {
                        @WeekCard(t)
                    }
                </div>
            }
        </div>
    }
    else if (_activeTab == "Stats")
    {
        <div class="bd-stats-grid">

            @* ① Tiến độ hôm nay *@
            <div class="bd-stat-card">
                <div class="bd-stat-card-label">Tiến độ hôm nay</div>
                <div class="bd-stat-pct">@TodayPct<span class="bd-stat-pct-sign">%</span></div>
                <div class="bd-seg-row">
                    @if (TodayTotal == 0)
                    {
                        <span class="bd-stat-hint">Không có việc hạn hôm nay</span>
                    }
                    else
                    {
                        @foreach (var t in TodayTasks)
                        {
                            <span class="bd-seg @(IsDone(t) ? "done" : "")"></span>
                        }
                    }
                </div>
                <div class="bd-stat-sub2">@TodayDone / @TodayTotal việc hoàn thành</div>
            </div>

            @* ② Phân bố trạng thái theo tuần *@
            <div class="bd-stat-card">
                <div class="bd-stat-card-label">Phân bố trạng thái theo tuần</div>
                <div class="bd-stat-range">Tuần @WeekStart().ToString("dd/MM") → @WeekEnd().ToString("dd/MM")</div>
                @{
                    var dist = new (string Label, string Color, int Count)[]
                    {
                        ("Trễ hạn", "#f28b8b", BucketedWeek("overdue")),
                        ("Cần làm", "rgba(255,255,255,.55)", BucketedWeek("todo")),
                        ("Đang làm", "#a996f2", BucketedWeek("doing")),
                        ("Hoàn thành", "#7bd8b0", BucketedWeek("done")),
                    };
                    var maxD = Math.Max(1, dist.Max(x => x.Count));
                }
                <div class="bd-dist">
                    @foreach (var d in dist)
                    {
                        <div class="bd-dist-row">
                            <span class="bd-dist-label">@d.Label</span>
                            <div class="bd-dist-track">
                                <div class="bd-dist-fill" style="width:@(d.Count * 100 / maxD)%;background:@d.Color"></div>
                            </div>
                            <span class="bd-dist-count">@d.Count</span>
                        </div>
                    }
                </div>
            </div>

            @* ③ Theo tag *@
            <div class="bd-stat-card">
                <div class="bd-stat-card-label">Theo tag</div>
                @{
                    var tagStats = TagStats();
                }
                @if (tagStats.Count == 0)
                {
                    <span class="bd-stat-hint">Chưa có dữ liệu tag</span>
                }
                else
                {
                    <div class="bd-tagstat-list">
                        @for (var i = 0; i < tagStats.Count; i++)
                        {
                            var ts = tagStats[i];
                            var color = TagColors[i % TagColors.Length];
                            <div class="bd-tagstat">
                                <div class="bd-tagstat-head">
                                    <span class="bd-tagstat-dot" style="background:@color"></span>
                                    <span class="bd-tagstat-name">@ts.Name</span>
                                    <span class="bd-tagstat-count">@ts.Done/@ts.Total</span>
                                </div>
                                <div class="bd-tagstat-track">
                                    <div class="bd-tagstat-fill" style="width:@(ts.Total == 0 ? 0 : ts.Done * 100 / ts.Total)%;background:@color"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* ④ Tổng quan *@
            <div class="bd-stat-card">
                <div class="bd-stat-card-label">Tổng quan</div>
                <div class="bd-overview">
                    <div class="bd-ov-item">
                        <div class="bd-ov-num green">@DoneTotal</div>
                        <div class="bd-ov-cap">Đã hoàn thành</div>
                    </div>
                    <div class="bd-ov-item">
                        <div class="bd-ov-num red">@OverdueCount</div>
                        <div class="bd-ov-cap">Trễ hạn</div>
                    </div>
                    <div class="bd-ov-item">
                        <div class="bd-ov-num purple">@DonePct%</div>
                        <div class="bd-ov-cap">Tỉ lệ hoàn thành</div>
                    </div>
                </div>
                @{
                    var overdueList = OverdueTasks().ToList();
                }
                @if (overdueList.Count == 0)
                {
                    <div class="bd-ov-note">@OverviewNote</div>
                }
                else
                {
                    <div class="bd-ov-overdue">
                        <div class="bd-ov-overdue-label">Việc đang trễ hạn</div>
                        @foreach (var t in overdueList)
                        {
                            <div class="bd-ov-overdue-item">
                                <span class="bd-ov-overdue-dot"></span>
                                <span class="bd-ov-overdue-name">@t.TodoItemName</span>
                                <span class="bd-ov-overdue-due">@t.DueDate?.ToString("dd/MM")</span>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    }
    else
    {
        <div class="bd-loading">Tab "@_activeTab" đang phát triển — sẽ làm ở bước sau.</div>
    }

    @* ---------- COMPOSER MODAL ---------- *@
    @if (_showComposer)
    {
        <div class="bd-overlay" @onclick="CloseComposer">
            <div class="bd-modal" @onclick:stopPropagation="true">
                <div class="bd-modal-head">
                    <div class="bd-modal-title">Công việc mới</div>
                    <button class="bd-x" @onclick="CloseComposer">×</button>
                </div>

                <input class="bd-input" placeholder="Tên công việc — vd: Ôn thi EF Core"
                       @bind="_dTitle" @bind:event="oninput" />

                <label class="bd-label">Mô tả</label>
                <textarea class="bd-input bd-textarea" rows="3" placeholder="Chi tiết, yêu cầu, ghi chú…"
                          @bind="_dDesc" @bind:event="oninput"></textarea>

                <div class="bd-row2">
                    <div>
                        <label class="bd-label">Bắt đầu</label>
                        <input type="date" class="bd-input" @bind="_dStart" />
                    </div>
                    <div>
                        <label class="bd-label">Hạn</label>
                        <input type="date" class="bd-input" @bind="_dDue" />
                    </div>
                </div>

                <label class="bd-label">Ưu tiên</label>
                <div class="bd-chips">
                    <button class="bd-chip @(_dPriority is null ? "sel" : "")" @onclick="() => _dPriority = null">None</button>
                    @foreach (var p in _priorities.Where(x => x.Id.HasValue))
                    {
                        <button class="bd-chip @(_dPriority == p.Id ? "sel" : "")" @onclick="() => _dPriority = p.Id">@p.PriorityName</button>
                    }
                </div>

                <label class="bd-label">Tag</label>
                <div class="bd-chips">
                    @if (_tags.Count == 0)
                    {
                        <span class="bd-hint">Chưa có tag nào</span>
                    }
                    @foreach (var tg in _tags.Where(x => x.Id.HasValue))
                    {
                        <button class="bd-chip @(_dTags.Contains(tg.Id!.Value) ? "sel" : "")" @onclick="() => ToggleTag(tg.Id!.Value)">@tg.TagName</button>
                    }
                </div>

                <label class="bd-label">Tham chiếu</label>
                <input class="bd-input" placeholder="Ghi chú / link…" @bind="_dRef" @bind:event="oninput" />

                <div class="bd-modal-foot">
                    <button class="bd-btn ghost" @onclick="CloseComposer">Hủy</button>
                    <button class="bd-btn primary" @onclick="SubmitComposer" disabled="@(string.IsNullOrWhiteSpace(_dTitle))">Thêm</button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private static readonly string[] Tabs = { "List", "Board", "Week", "Stats" };
    private string _activeTab = "Board";

    private List<TodoItemResponseDto>? _todos;
    private List<TagResponseDto> _tags = new();
    private List<PriorityResponseDto> _priorities = new();
    private string? _error;

    private string _search = "";

    // composer draft
    private bool _showComposer;
    private string _dTitle = "";
    private string _dDesc = "";
    private DateTime? _dStart;
    private DateTime? _dDue;
    private int? _dPriority;
    private readonly HashSet<int> _dTags = new();
    private string _dRef = "";

    private static DateTime Today => DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tags = await Api.GetTagsAsync();
            _priorities = await Api.GetPrioritiesAsync();
        }
        catch { /* tag/priority không chặn board */ }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _error = null;
            _todos = await Api.GetAllAsync();
        }
        catch (Exception ex)
        {
            _error = $"Không tải được dữ liệu: {ex.Message}";
        }
    }

    // ---- classify ----
    private static bool IsDone(TodoItemResponseDto t) => t.Status == "Done";
    private static bool IsOverdue(TodoItemResponseDto t)
        => !IsDone(t) && t.DueDate.HasValue && t.DueDate.Value.Date < Today;

    private static string Bucket(TodoItemResponseDto t)
    {
        if (IsDone(t)) return "done";
        if (IsOverdue(t)) return "overdue";
        return t.Status == "InProgress" ? "doing" : "todo";
    }

    private IEnumerable<TodoItemResponseDto> Filtered()
    {
        var q = _search.Trim().ToLowerInvariant();
        var items = _todos ?? new();
        return items
            .Where(t => q.Length == 0 || t.TodoItemName.ToLowerInvariant().Contains(q))
            .OrderBy(t => t.DueDate ?? DateTime.MaxValue);
    }

    private record Col(string Key, string Label, string Color, string Empty, List<TodoItemResponseDto> Tasks);

    private List<Col> Columns()
    {
        var f = Filtered().ToList();
        List<TodoItemResponseDto> In(string b) => f.Where(t => Bucket(t) == b).ToList();
        return new()
        {
            new("overdue", "Trễ hạn",   "#f28b8b", "Không có việc trễ — tuyệt!", In("overdue")),
            new("todo",    "Cần làm",   "rgba(255,255,255,.6)", "", In("todo")),
            new("doing",   "Đang làm",  "#a996f2", "Chưa có việc nào đang làm", In("doing")),
            new("done",    "Hoàn thành","#7bd8b0", "Chưa hoàn thành việc nào", In("done")),
        };
    }

    // ---- stats ----
    private int TodayTotal => (_todos ?? new()).Count(t => t.DueDate?.Date == Today);
    private int TodayDone => (_todos ?? new()).Count(t => t.DueDate?.Date == Today && IsDone(t));
    private int InProgressCount => (_todos ?? new()).Count(t => t.Status == "InProgress");
    private int OverdueCount => (_todos ?? new()).Count(IsOverdue);
    private int DoneTotal => (_todos ?? new()).Count(IsDone);

    // ---- stats view ----
    private int TotalCount => (_todos ?? new()).Count;
    private int Bucketed(string b) => (_todos ?? new()).Count(t => Bucket(t) == b);

    // Phân bố theo tuần: chỉ việc có hạn nằm trong tuần hiện tại
    private int BucketedWeek(string b)
    {
        var start = WeekStart();
        var end = WeekEnd();
        return (_todos ?? new()).Count(t =>
            t.DueDate.HasValue
            && t.DueDate.Value.Date >= start && t.DueDate.Value.Date <= end
            && Bucket(t) == b);
    }
    private int TodayPct => TodayTotal == 0 ? 0 : (int)Math.Round(TodayDone * 100.0 / TodayTotal);
    private int DonePct => TotalCount == 0 ? 0 : (int)Math.Round(DoneTotal * 100.0 / TotalCount);
    private IEnumerable<TodoItemResponseDto> TodayTasks
        => (_todos ?? new()).Where(t => t.DueDate?.Date == Today);

    // Bảng màu cho tag — lấy từ palette của prototype (không phát sinh màu mới)
    private static readonly string[] TagColors =
        { "#a996f2", "#8ab4ff", "#7bd8b0", "#e8c97a", "#f2a2c0", "#7fd4e0" };

    private IEnumerable<TodoItemResponseDto> OverdueTasks()
        => (_todos ?? new()).Where(IsOverdue).OrderBy(t => t.DueDate);

    private record TagStat(string Name, int Done, int Total);

    private List<TagStat> TagStats()
    {
        var items = _todos ?? new();
        var stats = new List<TagStat>();
        foreach (var tg in _tags.Where(x => x.Id.HasValue))
        {
            var withTag = items.Where(t => t.Tags.Any(x => x.Id == tg.Id)).ToList();
            if (withTag.Count > 0)
                stats.Add(new TagStat(tg.TagName, withTag.Count(IsDone), withTag.Count));
        }
        var noTag = items.Where(t => t.Tags.Count == 0).ToList();
        if (noTag.Count > 0)
            stats.Add(new TagStat("Không tag", noTag.Count(IsDone), noTag.Count));
        return stats.OrderByDescending(s => s.Total).ToList();
    }

    private string OverviewNote
    {
        get
        {
            if (TotalCount == 0) return "Chưa có công việc nào — thêm việc để bắt đầu.";
            if (OverdueCount > 0) return $"Còn {OverdueCount} việc trễ hạn — xử lý sớm nhé.";
            if (DoneTotal == TotalCount) return "Tất cả đã xong — tuyệt vời!";
            return "Đang đúng tiến độ, giữ nhịp nhé.";
        }
    }

    private static string DueLabel(TodoItemResponseDto t)
    {
        if (IsDone(t)) return "✓";
        if (!t.DueDate.HasValue) return "";
        var d = t.DueDate.Value;
        var datePart = d.Date == Today ? "hôm nay" : d.ToString("dd/MM");
        var timePart = d.TimeOfDay == TimeSpan.Zero ? "" : " " + d.ToString("HH:mm");
        return datePart + timePart;
    }

    // ---- card template ----
    private RenderFragment Card(TodoItemResponseDto t) =>@<div class="bd-card @Bucket(t)">
        <div class="bd-card-top">
            <button class="bd-check @(IsDone(t) ? "done" : "")" title="Đổi hoàn thành" @onclick="() => ToggleDone(t)">@(IsDone(t) ? "✓" : "")</button>
            <div class="bd-card-title @(IsDone(t) ? "done" : "")">@t.TodoItemName</div>
            <button class="bd-del" title="Xóa" @onclick="() => Delete(t)">×</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(t.Description))
        {
            <div class="bd-desc">@t.Description</div>
        }
        @if (t.Tags.Count > 0 || !string.IsNullOrWhiteSpace(t.PriorityName))
        {
            <div class="bd-meta">
                @foreach (var tag in t.Tags)
                {
                    <span class="bd-tag">@tag.TagName</span>
                }
                @if (!string.IsNullOrWhiteSpace(t.PriorityName))
                {
                    <span class="bd-pri">@t.PriorityName</span>
                }
            </div>
        }
        <div class="bd-card-foot">
            <span class="bd-due">@DueLabel(t)</span>
            @if (Bucket(t) == "todo")
            {
                <button class="bd-act start" @onclick="() => Start(t)">start</button>
            }
            else if (Bucket(t) == "doing")
            {
                <button class="bd-act stop" @onclick="() => Stop(t)">stop</button>
            }
        </div>
    </div>;

    // ---- list row template ----
    private RenderFragment Row(TodoItemResponseDto t) =>@<div class="bd-row @Bucket(t)">
        <button class="bd-check @(IsDone(t) ? "done" : "")" title="Đổi hoàn thành" @onclick="() => ToggleDone(t)">@(IsDone(t) ? "✓" : "")</button>
        <span class="bd-row-title @(IsDone(t) ? "done" : "")">@t.TodoItemName</span>
        @foreach (var tag in t.Tags)
        {
            <span class="bd-tag">@tag.TagName</span>
        }
        @if (!string.IsNullOrWhiteSpace(t.PriorityName))
        {
            <span class="bd-pri">@t.PriorityName</span>
        }
        <span class="bd-row-due">@DueLabel(t)</span>
        @if (Bucket(t) == "todo")
        {
            <button class="bd-act start" @onclick="() => Start(t)">start</button>
        }
        else if (Bucket(t) == "doing")
        {
            <button class="bd-act stop" @onclick="() => Stop(t)">stop</button>
        }
        <button class="bd-del" title="Xóa" @onclick="() => Delete(t)">×</button>
    </div>;

    // ---- week helpers ----
    private static DateTime WeekStart()
    {
        var diff = ((int)Today.DayOfWeek + 6) % 7; // Thứ Hai = 0
        return Today.AddDays(-diff);
    }

    private static DateTime WeekEnd() => WeekStart().AddDays(6);

    private static IEnumerable<DateTime> WeekDays()
        => Enumerable.Range(0, 7).Select(i => WeekStart().AddDays(i));

    private static string DowVi(DateTime d) => d.DayOfWeek switch
    {
        DayOfWeek.Monday => "T2",
        DayOfWeek.Tuesday => "T3",
        DayOfWeek.Wednesday => "T4",
        DayOfWeek.Thursday => "T5",
        DayOfWeek.Friday => "T6",
        DayOfWeek.Saturday => "T7",
        _ => "CN",
    };

    private static string WeekTime(TodoItemResponseDto t)
    {
        if (!t.DueDate.HasValue) return "";
        var d = t.DueDate.Value;
        return d.TimeOfDay == TimeSpan.Zero ? "" : d.ToString("HH:mm");
    }

    private RenderFragment WeekCard(TodoItemResponseDto t) =>@<div class="bd-week-card @Bucket(t)">
        <div class="bd-week-card-top">
            <button class="bd-check @(IsDone(t) ? "done" : "")" title="Đổi hoàn thành" @onclick="() => ToggleDone(t)">@(IsDone(t) ? "✓" : "")</button>
            <span class="bd-week-card-title @(IsDone(t) ? "done" : "")">@t.TodoItemName</span>
            <button class="bd-del" title="Xóa" @onclick="() => Delete(t)">×</button>
        </div>
        @if (t.Tags.Count > 0 || WeekTime(t).Length > 0)
        {
            <div class="bd-week-meta">
                @foreach (var tag in t.Tags)
                {
                    <span class="bd-tag">@tag.TagName</span>
                }
                @if (WeekTime(t).Length > 0)
                {
                    <span class="bd-week-time">@WeekTime(t)</span>
                }
            </div>
        }
    </div>;

    // ---- actions ----
    private Task ToggleDone(TodoItemResponseDto t) => SetStatus(t, IsDone(t) ? "Pending" : "Done");
    private Task Start(TodoItemResponseDto t) => SetStatus(t, "InProgress");
    private Task Stop(TodoItemResponseDto t) => SetStatus(t, "Pending");

    private async Task SetStatus(TodoItemResponseDto t, string status)
    {
        try
        {
            await Api.UpdateStatusAsync(t.Id, status);
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Đổi trạng thái thất bại: {ex.Message}"; }
    }

    private async Task Delete(TodoItemResponseDto t)
    {
        try
        {
            await Api.DeleteAsync(t.Id);
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Xóa thất bại: {ex.Message}"; }
    }

    // ---- composer ----
    private void OpenComposer()
    {
        _dTitle = ""; _dDesc = ""; _dRef = "";
        _dStart = null; _dDue = null; _dPriority = null; _dTags.Clear();
        _showComposer = true;
    }

    private void CloseComposer() => _showComposer = false;

    private void ToggleTag(int id)
    {
        if (!_dTags.Add(id)) _dTags.Remove(id);
    }

    private async Task SubmitComposer()
    {
        if (string.IsNullOrWhiteSpace(_dTitle)) return;
        try
        {
            await Api.CreateAsync(new CreateTodoItemDto
            {
                TodoItemName = _dTitle.Trim(),
                TodoItemDescription = _dDesc,
                TagIds = _dTags.Count > 0 ? _dTags.ToList() : null,
                StartDate = _dStart,
                DueDate = _dDue,
                PriorityId = _dPriority,
                ReferenceNote = _dRef
            });
            _showComposer = false;
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Tạo công việc thất bại: {ex.Message}"; }
    }
}
